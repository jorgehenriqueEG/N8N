nly.\\n5. SECOND LINE: Must be exactly \"START_STORY\".\\n\\n${universeHook}\\n`;\n\nreturn [{\n  json: {\n    ...$json,\n    prompt,\n    videoType,\n    theme\n  }\n}];\n"
